# ============================================
# 考研伴学 Agent - 环境变量配置模板
# ============================================
# 使用方式：
#   cp .env.example .env
#   然后编辑 .env 填入真实值

# ---- 基础信息 ----
PROJECT_NAME=考研伴学 Agent
PROJECT_VERSION=0.1.0
DEBUG=true

# ============================================
# 默认模型：DeepSeek V4（兼容 OpenAI 格式）
# ============================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# [TODO: 请在此填入你的 DeepSeek API Key]
#  申请地址：https://platform.deepseek.com/api_keys

DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# 本地嵌入模型 —— DeepSeek 不提供 Embedding API
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# HuggingFace 国内镜像（解决网络不通问题）
HF_ENDPOINT=https://hf-mirror.com

# ============================================
# 备用模型：Qwen / 通义千问（兼容 OpenAI 格式）
# ============================================
QWEN_API_KEY=
# [TODO: 如需使用阿里云通义千问作为备用模型，
#   请填入 Qwen API Key。
#   申请地址：https://dashscope.console.aliyun.com/apiKey]

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_NAME=qwen-plus

# [TODO: 如需添加第三个模型（如 OpenAI 原生），参考上方模式新增环境变量，
#   然后在 llm_manager.py 的 _PROVIDER_CONFIGS 字典中注册即可。]

# ============================================
# 数据存储路径（相对于项目根目录）
# ============================================
CHROMA_PERSIST_DIR=./data/chroma_db
RAW_DOCS_DIR=./data/raw_docs
SUMMARY_DB_DIR=./data/summary_db

# ============================================
# 文档切分配置
# ============================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# 按 Markdown 标题切分的层级（2 = 按 H2 切分，保留章-节结构）
MARKDOWN_SPLIT_HEADER_LEVEL=2

# 解析器能识别的最大标题层级（防止正文中的 # 编号被误当标题）
MARKDOWN_HEADER_MAX_LEVEL=4

# ============================================
# RAG 检索配置
# ============================================
RETRIEVAL_K=4
RETRIEVAL_THRESHOLD=0.0

# ============================================
# API 服务配置
# ============================================
HOST=0.0.0.0
PORT=8000
